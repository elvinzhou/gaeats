{
  "name": "gaeats",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "deploy": "pnpm run build && wrangler deploy",
    "dev": "react-router dev",
    "import:faa-airports": "node --experimental-transform-types scripts/import-faa-airports.js",
    "postinstall": "pnpm run cf-typegen && prisma generate",
    "preview": "pnpm run build && vite preview",
    "sync:google-pois": "node --experimental-transform-types scripts/sync-google-pois.js",
    "sync:mvp": "node --experimental-transform-types scripts/sync-mvp.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:smoke": "node --experimental-transform-types scripts/smoke-test.ts",
    "typecheck": "pnpm run cf-typegen && react-router typegen && tsc -b"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0",
    "@prisma/extension-accelerate": "^3.0.1",
    "@vis.gl/react-google-maps": "^1.8.2",
    "isbot": "^5.1.37",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.14.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.0",
    "@react-router/dev": "^7.14.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.2",
    "dotenv": "^17.4.1",
    "prisma": "^7.6.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.2",
    "wrangler": "^4.80.0"
  }
}

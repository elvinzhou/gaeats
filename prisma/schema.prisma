// Prisma Schema for GA Eats - Fly-in Dining Discovery Platform
// learn more: https://pris.ly/d/prisma-schema

/**
 * Generator Configuration
 * - Uses the Prisma v7 TypeScript generator
 * - Targets the Cloudflare Workers/workerd runtime
 * - Outputs to app/generated/prisma for app-local imports
 */
generator client {
  provider               = "prisma-client"
  output                 = "../app/generated/prisma"
  runtime                = "workerd"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "js"
  previewFeatures        = ["postgresqlExtensions"]
}

generator scriptClient {
  provider               = "prisma-client"
  output                 = "../scripts/generated/prisma"
  runtime                = "nodejs"
  moduleFormat           = "esm"
  generatedFileExtension = "ts"
  importFileExtension    = "ts"
  previewFeatures        = ["postgresqlExtensions"]
}

/**
 * Database Configuration
 * - Uses PostgreSQL with PostGIS extension for geospatial queries
 * - Connection URLs configured in prisma.config.ts (Prisma v7)
 */
datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}

enum PoiType {
  RESTAURANT
  ATTRACTION
}

enum ExternalSource {
  GOOGLE_MAPS
  YELP
  MANUAL
  CLAIMED_LISTING
  IMPORT
}

enum AccessMode {
  WALKING
  BIKING
  TRANSIT
  RIDESHARE
  CREW_CAR
  COURTESY_SHUTTLE
  RESTAURANT_SHUTTLE
  DRIVING
}

enum AvailabilityStatus {
  YES
  NO
  LIMITED
  UNKNOWN
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
}

enum AccessSourceType {
  AIRPORT
  FBO
  RESTAURANT
  PILOT_REVIEW
  CLAIMED_LISTING
  INFERRED
  MANUAL
}

enum VerificationMethod {
  OPERATOR_CONFIRMATION
  PUBLISHED_SOURCE
  PILOT_CONFIRMATION
  CLAIMED_LISTING_UPDATE
  INFERENCE
  MANUAL
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum ClaimStatus {
  PENDING
  VERIFIED
  REJECTED
  REVOKED
}

enum AirportSource {
  FAA
  MANUAL
}

/**
 * Airport Model
 * Represents public-use airports where pilots can land
 * Fields:
 * - id: Unique identifier
 * - code: IATA/ICAO airport code (e.g., "KSFO", "SFO")
 * - name: Full airport name
 * - city: City name
 * - state: State/Province code (e.g., "CA")
 * - country: Country code (e.g., "US")
 * - location: PostGIS geography point (latitude, longitude) using SRID 4326 (WGS 84)
 * - createdAt: Timestamp of record creation
 * - updatedAt: Timestamp of last update
 */
model Airport {
  id             Int                                   @id @default(autoincrement())
  code           String                                @unique @db.VarChar(10)
  faaCode        String?                               @unique @db.VarChar(10)
  icaoCode       String?                               @unique @db.VarChar(10)
  iataCode       String?                               @unique @db.VarChar(10)
  source         AirportSource                         @default(MANUAL)
  sourceDataset  String?                               @db.VarChar(255)
  sourceRecordUpdatedAt DateTime?                      @db.Timestamptz
  sourceRefreshedAt DateTime?                          @db.Timestamptz
  facilityType          String?  @db.VarChar(20)
  ownershipType         String?  @db.VarChar(5)
  airportUse            String?  @db.VarChar(5)
  elevation             Float?   @db.DoublePrecision
  siteNumber            String?  @db.VarChar(11)
  faaRegionCode         String?  @db.VarChar(3)
  stateName             String?  @db.VarChar(20)
  countyName            String?  @db.VarChar(21)
  countyState           String?  @db.VarChar(2)
  ownerName             String?  @db.VarChar(35)
  ownerPhone            String?  @db.VarChar(16)
  managerName           String?  @db.VarChar(35)
  managerPhone          String?  @db.VarChar(16)
  magVariation          String?  @db.VarChar(3)
  magVariationYear      String?  @db.VarChar(4)
  trafficPatternAltitude Int?
  sectionalChart        String?  @db.VarChar(30)
  distanceFromCity      Int?
  directionFromCity     String?  @db.VarChar(3)
  acreage               Int?
  artccBoundaryId       String?  @db.VarChar(4)
  artccResponsibleId    String?  @db.VarChar(4)
  notamFacility         String?  @db.VarChar(4)
  notamDService         String?  @db.VarChar(1)
  activationDate        String?  @db.VarChar(7)
  airportStatus         String?  @db.VarChar(2)
  arffCertification     String?  @db.VarChar(15)
  npiasAgreements       String?  @db.VarChar(7)
  airspaceAnalysis      String?  @db.VarChar(13)
  customsEntry          String?  @db.VarChar(1)
  customsLanding        String?  @db.VarChar(1)
  jointUse              String?  @db.VarChar(1)
  militaryRights        String?  @db.VarChar(1)
  fuelTypes             String?  @db.VarChar(40)
  airframeRepair        String?  @db.VarChar(5)
  engineRepair          String?  @db.VarChar(5)
  bottledOxygen         String?  @db.VarChar(8)
  bulkOxygen            String?  @db.VarChar(8)
  lightingSchedule      String?  @db.VarChar(7)
  beaconSchedule        String?  @db.VarChar(7)
  controlTower          String?  @db.VarChar(1)
  unicomFrequency       String?  @db.VarChar(7)
  ctafFrequency         String?  @db.VarChar(7)
  segmentedCircle       String?  @db.VarChar(4)
  beaconColor           String?  @db.VarChar(3)
  landingFee            String?  @db.VarChar(1)
  singleEngineCount     Int?
  multiEngineCount      Int?
  jetEngineCount        Int?
  helicopterCount       Int?
  gliderCount           Int?
  militaryCount         Int?
  ultralightCount       Int?
  annualCommercialOps   Int?
  annualCommuterOps     Int?
  annualAirTaxiOps      Int?
  annualGaLocalOps      Int?
  annualGaItinerantOps  Int?
  annualMilitaryOps     Int?
  annualOpsDate         String?  @db.VarChar(10)
  contractFuel          String?  @db.VarChar(1)
  storageFacilities     String?  @db.VarChar(12)
  otherServices         String?  @db.VarChar(71)
  windIndicator         String?  @db.VarChar(3)
  minOperationalNetwork String?  @db.VarChar(1)
  name           String                                @db.VarChar(255)
  city           String                                @db.VarChar(100)
  state          String?                               @db.VarChar(10)
  country        String                                @default("US") @db.VarChar(10)
  fboName        String?                               @db.VarChar(255)
  fboPhone       String?                               @db.VarChar(50)
  fboWebsite     String?                               @db.VarChar(500)
  notes          String?                               @db.Text
  lastVerifiedAt DateTime?                             @db.Timestamptz
  lastPoiSyncAt  DateTime?                             @db.Timestamptz
  nextPoiSyncAt  DateTime?                             @db.Timestamptz
  syncPriority   Int                                   @default(100)
  location       Unsupported("geography(Point, 4326)") // PostGIS geography type for efficient distance calculations
  createdAt      DateTime                              @default(now()) @db.Timestamptz
  updatedAt      DateTime                              @updatedAt @db.Timestamptz

  accessFacts   AirportAccessFact[]
  poiLinks      AirportPoi[]
  pilotReviews  PilotReview[]
  accessReports PilotAccessReport[]

  @@index([location], type: Gist) // Spatial index for fast geospatial queries
  @@index([nextPoiSyncAt, syncPriority])
  @@map("airports")
}

/**
 * Point of interest target model for MVP.
 * This is the canonical listing model for both restaurants and attractions.
 */
model Poi {
  id                  Int                                   @id @default(autoincrement())
  source              ExternalSource
  externalSourceId    String?                               @db.VarChar(255)
  type                PoiType
  name                String                                @db.VarChar(255)
  category            String?                               @db.VarChar(100)
  subcategory         String?                               @db.VarChar(100)
  cuisine             String?                               @db.VarChar(100)
  description         String?                               @db.Text
  address             String                                @db.VarChar(500)
  city                String                                @db.VarChar(100)
  state               String?                               @db.VarChar(10)
  country             String                                @default("US") @db.VarChar(10)
  priceLevel          Int?
  externalRating      Float?                                @db.DoublePrecision
  externalReviewCount Int?
  pilotRating         Float?                                @db.DoublePrecision
  pilotReviewCount    Int                                   @default(0)
  url                 String?                               @db.VarChar(500)
  phone               String?                               @db.VarChar(50)
  hoursJson           Json?
  active              Boolean                               @default(true)
  lastSyncedAt        DateTime?                             @db.Timestamptz
  location            Unsupported("geography(Point, 4326)") // PostGIS geography type for efficient distance calculations
  createdAt           DateTime                              @default(now()) @db.Timestamptz
  updatedAt           DateTime                              @updatedAt @db.Timestamptz

  airportLinks  AirportPoi[]
  accessFacts   PoiAccessFact[]
  pilotReviews  PilotReview[]
  accessReports PilotAccessReport[]
  listingClaims ListingClaim[]

  @@unique([source, externalSourceId])
  @@index([type])
  @@index([externalRating])
  @@index([pilotRating])
  @@index([location], type: Gist)
  @@map("pois")
}

/**
 * Join model between airports and points of interest.
 * Stores route-derived last-mile estimates and the derived reachability summary
 * that powers ranking for "practical after landing" results.
 */
model AirportPoi {
  id                         Int              @id @default(autoincrement())
  airportId                  Int
  poiId                      Int
  straightLineDistanceMeters Float?           @db.DoublePrecision
  walkingMinutes             Int?
  bikingMinutes              Int?
  transitMinutes             Int?
  drivingMinutes             Int?
  preferredMode              AccessMode?
  accessConfidence           ConfidenceLevel?
  reachabilityScore          Float?           @db.DoublePrecision
  needsCrewCar               Boolean?
  needsRideshare             Boolean?
  accessSummary              String?          @db.Text
  lastCalculatedAt           DateTime?        @db.Timestamptz
  createdAt                  DateTime         @default(now()) @db.Timestamptz
  updatedAt                  DateTime         @updatedAt @db.Timestamptz

  airport Airport @relation(fields: [airportId], references: [id], onDelete: Cascade)
  poi     Poi     @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@unique([airportId, poiId])
  @@index([preferredMode])
  @@index([reachabilityScore])
  @@map("airport_pois")
}

model AirportAccessFact {
  id                 Int                 @id @default(autoincrement())
  airportId          Int
  mode               AccessMode
  status             AvailabilityStatus  @default(UNKNOWN)
  confidence         ConfidenceLevel     @default(LOW)
  sourceType         AccessSourceType
  sourceDetail       String?             @db.Text
  sourceUrl          String?             @db.VarChar(500)
  note               String?             @db.Text
  lastVerifiedAt     DateTime?           @db.Timestamptz
  verificationMethod VerificationMethod?
  createdAt          DateTime            @default(now()) @db.Timestamptz
  updatedAt          DateTime            @updatedAt @db.Timestamptz

  airport Airport @relation(fields: [airportId], references: [id], onDelete: Cascade)

  @@unique([airportId, mode])
  @@index([status, confidence])
  @@index([lastVerifiedAt])
  @@map("airport_access_facts")
}

model PoiAccessFact {
  id                 Int                 @id @default(autoincrement())
  poiId              Int
  mode               AccessMode
  status             AvailabilityStatus  @default(UNKNOWN)
  confidence         ConfidenceLevel     @default(LOW)
  sourceType         AccessSourceType
  sourceDetail       String?             @db.Text
  sourceUrl          String?             @db.VarChar(500)
  note               String?             @db.Text
  lastVerifiedAt     DateTime?           @db.Timestamptz
  verificationMethod VerificationMethod?
  createdAt          DateTime            @default(now()) @db.Timestamptz
  updatedAt          DateTime            @updatedAt @db.Timestamptz

  poi Poi @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@unique([poiId, mode])
  @@index([status, confidence])
  @@index([lastVerifiedAt])
  @@map("poi_access_facts")
}

model PilotReview {
  id               Int              @id @default(autoincrement())
  airportId        Int?
  poiId            Int
  rating           Int
  title            String?          @db.VarChar(255)
  body             String?          @db.Text
  tags             String[]
  visitedAt        DateTime?        @db.Timestamptz
  moderationStatus ModerationStatus @default(PENDING)
  createdAt        DateTime         @default(now()) @db.Timestamptz
  updatedAt        DateTime         @updatedAt @db.Timestamptz

  airport Airport? @relation(fields: [airportId], references: [id], onDelete: SetNull)
  poi     Poi      @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@index([poiId, moderationStatus])
  @@index([airportId, moderationStatus])
  @@map("pilot_reviews")
}

/**
 * Lightweight confirmations for operational access details.
 * These records are intended to fight stale airport/FBO transport data with
 * low-effort pilot feedback such as "crew car worked" or "no rideshare found".
 */
model PilotAccessReport {
  id               Int                @id @default(autoincrement())
  airportId        Int
  poiId            Int?
  mode             AccessMode
  status           AvailabilityStatus
  confidence       ConfidenceLevel?
  note             String?            @db.Text
  happenedAt       DateTime?          @db.Timestamptz
  moderationStatus ModerationStatus   @default(PENDING)
  createdAt        DateTime           @default(now()) @db.Timestamptz
  updatedAt        DateTime           @updatedAt @db.Timestamptz

  airport Airport @relation(fields: [airportId], references: [id], onDelete: Cascade)
  poi     Poi?    @relation(fields: [poiId], references: [id], onDelete: SetNull)

  @@index([airportId, mode, moderationStatus])
  @@index([poiId, mode, moderationStatus])
  @@map("pilot_access_reports")
}

model AirportFuelCache {
  id        Int      @id @default(autoincrement())
  icao      String   @unique @db.VarChar(10)
  hasFuel   Boolean
  fbos      Json
  fetchedAt DateTime @db.Timestamptz
  createdAt DateTime @default(now()) @db.Timestamptz
  updatedAt DateTime @updatedAt @db.Timestamptz

  @@map("airport_fuel_cache")
}

model ListingClaim {
  id                Int         @id @default(autoincrement())
  poiId             Int
  claimantName      String      @db.VarChar(255)
  claimantEmail     String      @db.VarChar(255)
  claimantPhone     String?     @db.VarChar(50)
  businessName      String?     @db.VarChar(255)
  website           String?     @db.VarChar(500)
  status            ClaimStatus @default(PENDING)
  verificationNotes String?     @db.Text
  createdAt         DateTime    @default(now()) @db.Timestamptz
  updatedAt         DateTime    @updatedAt @db.Timestamptz

  poi Poi @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([claimantEmail])
  @@map("listing_claims")
}
